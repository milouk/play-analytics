# Copy to .env and fill in.
# Found in Play Console > Settings > Developer account > Account details.
DEVELOPER_ACCOUNT_ID=1234567890123456789

# Comma-separated list of apps. Each entry is either `package` or
# `package:Pretty Name`. Apps must belong to the developer account above.
APPS=com.example.app1:My First App,com.example.app2:My Second App

# --- credentials (pick ONE) ---
# Path to the service account JSON key (mount it into the container):
#   docker run -v $(pwd)/key.json:/secrets/key.json -e GOOGLE_APPLICATION_CREDENTIALS=/secrets/key.json ...
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/key.json

# Or the JSON content directly (preferred for CI / env-only deploys):
#   docker run -e GOOGLE_APPLICATION_CREDENTIALS_JSON="$(cat key.json)" ...
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Optional: where to write data + output (defaults shown).
# DATA_DIR=/app/data
# OUTPUT_DIR=/app/output

# Optional: start built-in HTTP server after rendering.
# SERVE=true
# PORT=8080

# Optional: time-window dashboards to render (comma-separated).
# Each becomes a tab in the dashboard: 7d, 30d, all-time, etc.
# Default: 7,30,all
# WINDOWS=7,30,all

# Optional: refresh on a cron schedule (handled by supercronic inside
# the image). Standard 5-field cron. Default: no schedule (render once).
# Daily at 06:00 UTC — Play reports lag ~48 h, so morning is safe.
# CRON_SCHEDULE=0 6 * * *
